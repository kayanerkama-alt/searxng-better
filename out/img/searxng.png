  <ellipse cx="20" cy="20" rx="22" ry="8" fill="none" stroke="url(#atomic-logo)" stroke-width="1.5" transform="rotate(30 20 20)"/>
  <text x="50" y="26" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="url(#atomic-logo)">Atomic Search</text>
