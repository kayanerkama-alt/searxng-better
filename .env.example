# ============================================
# Atomic Search - Environment Variables
# ============================================
# Copy this file to .env and configure for your deployment

# Instance Settings
NAME=Atomic Search
BASE_URL=https://your-domain.com/
SECRET_KEY=your-secret-key-here

# Privacy & Performance
IMAGE_PROXY=true
SAFE_SEARCH=1
AUTOCOMPLETE=google
HTTP_PROTOCOL_VERSION=1.1

# Rate Limiting (requires Redis)
LIMITER=true
REDIS_URL=redis://localhost:6379/0

# Branding
PRIVACYPOLICY=https://your-domain.com/privacy
CONTACT=https://your-domain.com/contact
ISSUE_URL=https://github.com/your-repo/issues
FOOTER_MESSAGE=Made with ❤️ by Your Name

# Search Engine Defaults
GOOGLE_DEFAULT=true
BING_DEFAULT=false
BRAVE_DEFAULT=false
DUCKDUCKGO_DEFAULT=false
WIKIPEDIA_DEFAULT=false
SEARCH_DEFAULT_LANG=auto

# Advanced
OPENMETRICS=
AUTHORIZED_API=
MARGINALIA_API=

# Docker/Railway/Render
GRANIAN_HOST=0.0.0.0
GRANIAN_PORT=8080
